# ---------------------------------------------------------
neurometric-platform
neurometric-platform.exe

server
server.exe

*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# ---------------------------------------------------------
# Go Coverage / Profiling
# ---------------------------------------------------------
coverage.out
*.prof

# ---------------------------------------------------------
# Database Files
# ---------------------------------------------------------
data/
*.db
*.sqlite
*.sqlite3
neurometric.db

# ---------------------------------------------------------
# Environment Variables
# ---------------------------------------------------------
.env
.env.local
.env.production

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------
# Node Modules (Future Frontend Expansion)
# ---------------------------------------------------------
node_modules/

# ---------------------------------------------------------
# Python / AI Processing
# ---------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
venv/

# ---------------------------------------------------------
# IDE / Editor Files
# ---------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------
# OS Files
# ---------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------
tmp/
temp/
*.tmp

# ---------------------------------------------------------
# AI / ML Models
# ---------------------------------------------------------
models/
checkpoints/
*.h5
*.pt
*.pth
*.onnx

# ---------------------------------------------------------
# Cache / Render Files
# ---------------------------------------------------------
cache/
renders/

# ---------------------------------------------------------
# Build Outputs
# ---------------------------------------------------------
dist/
build/

# ---------------------------------------------------------
# Optional Large Assets
# Uncomment if needed later
# ---------------------------------------------------------
# assets/raw/
# assets/videos/
# assets/voice-recordings/

# ---------------------------------------------------------
